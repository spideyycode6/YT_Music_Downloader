# ===== API CONFIGURATION =====
# Backend API URL for making requests from the frontend
# 
# DEVELOPMENT OPTIONS:
#   1. Leave empty: Uses Vite dev proxy (/api → localhost:5000) - Requires backend running
#   2. Set to http://localhost:5000: Direct API calls without proxy - Requires backend CORS enabled
#
# PRODUCTION:
#   Set to your production API URL (e.g., https://api.yourdomain.com)
#
# Default: Empty (uses Vite proxy during dev)
VITE_API_URL=
