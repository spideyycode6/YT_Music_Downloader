# ===== SERVER CONFIGURATION =====
# Port number for the backend server
# Default: 3000
PORT=5000

# ===== DATABASE =====
# MongoDB connection URI
# Format: mongodb://[username:password@]hostname[:port]/[database][?options]
# Required for production
MONGO_URI=mongodb://localhost:27017/yt_music_downloader

# ===== AUTHENTICATION - JWT (REQUIRED) =====
# Secret key for signing JWT tokens
# ⚠️ MUST be changed to a strong, unique value before production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# JWT token expiration time
# Default: 1h
JWT_EXPIRES_IN=1h

# Secret key for signing refresh tokens
# ⚠️ MUST be changed to a strong, unique value before production
REFRESH_TOKEN_SECRET=your_refresh_token_secret_key_here_change_in_production

# Refresh token expiration time
# Default: 7d
REFRESH_TOKEN_EXPIRES_IN=7d

# ===== IMAGEKIT CONFIGURATION (REQUIRED) =====
# ImageKit API credentials for image optimization and hosting
# Get from: https://imagekit.io/dashboard/developer/api-keys
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# ===== GOOGLE OAUTH (Optional) =====
# Google OAuth credentials for authentication
# Get from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ===== CORS CONFIGURATION =====
# Comma-separated list of frontend origins allowed to access the API
# For development: http://localhost:5173,http://localhost:5174
# For production: https://yourdomain.com
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:5174

# ===== AUDIO PROCESSING =====
# Enable audio compression for downloads
# Default: false
ENABLE_AUDIO_COMPRESSION=false

# Maximum audio file size in bytes before compression is applied
# Default: 60MB (60 * 1024 * 1024)
MAX_AUDIO_BUFFER_BYTES=62914560

# Maximum video duration allowed for download in seconds
# Default: 900 seconds (15 minutes)
MAX_DURATION_SECONDS=900

# ===== DOWNLOAD JOB MANAGEMENT =====
# Maximum number of concurrent download jobs
# Default: 3
MAX_ACTIVE_JOBS=3

# Time-to-live for download links in minutes
# Default: 60 minutes
DOWNLOAD_TTL_MINUTES=60

# Time after download completion before file is deleted in minutes
# Default: 10 minutes
DELETE_AFTER_DOWNLOAD_MINUTES=10

# Cleanup job interval in milliseconds (removes expired downloads)
# Default: 5 minutes (5 * 60 * 1000)
CLEANUP_INTERVAL_MS=300000

# ===== STORAGE =====
# Maximum file size ImageKit can store in bytes
# Default: 19MB (19 * 1024 * 1024)
IMAGEKIT_MAX_BYTES=19922944

# Minimum free disk space required before downloads are disabled in bytes
# Default: 2MB (2 * 1024 * 1024)
MIN_STORAGE_HEADROOM_BYTES=2097152
